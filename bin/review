#!/bin/sh
set -eu

default_base="main"
requested_base="$default_base"
requested_mr_url=""
requested_review_branch=""
mode="prompt"
include_duo="false"
resolve_duo="false"
comment_on_mr="false"
explicit_base="false"
requested_base_is_mr_url="false"
need_gitlab_api="false"
need_primary_mr_context="false"
primary_mr_context_loaded="false"

usage() {
  cat <<EOF
Usage:
  review [--copilot] [--base <branch-or-commit-or-mr-url>] [--duo [--resolve]] [--comment] [<branch-name-or-merge-request-url>]
  review --help

Generate a Copilot review prompt for the current branch. By default, this prints
the generated prompt. Use --copilot to pass it to GitHub Copilot CLI.

Options:
  --copilot              Pass the generated prompt to GitHub Copilot CLI
  --base <ref>           Compare against the given base branch, commit hash, or
                         GitLab merge request URL. Useful for stacked merge
                         requests. Default: $default_base
  --duo                  Find unresolved GitLab Duo comments for the target merge
                         request and append them to the prompt
  --resolve              With --duo, ask Copilot to reply to and resolve Duo
                         comments that are incorrect, irrelevant, or too nitpicky
  --comment              Ask Copilot to post substantive review findings back to
                         the target GitLab merge request as inline comments
  -h, --help             Show this help text

Arguments:
  <branch-name-or-merge-request-url>
                         Review the given remote branch or GitLab merge request.
                         Branch reviews fetch the remote branch, switch to the
                         local branch, and ensure it matches the remote exactly.
                         Merge request reviews fetch the MR branch, switch to the
                         exact source branch, and then start the review

Notes:
  --resolve requires --duo.
  GitLab features (MR URLs, --duo, --comment, --resolve) require curl, jq, and
  GITLAB_TOKEN or GITLAB_ACCESS_TOKEN.
  Branch and MR URL reviews require a clean working tree.
  Existing local branches are only reused when they already match the fetched
  remote branch or can be fast-forwarded to it.
  MR URL review requires a configured git remote that matches the MR source
  project.

Examples:
  review
    Print a review prompt for the current branch against main.
  review --copilot
    Pass the generated prompt for the current branch against main to GitHub Copilot CLI.
  review --base feature/parent
    Print a review prompt for the current branch against another branch for a stacked MR.
  review feature/child
    Fetch that remote branch, switch to it safely, and print the review prompt against main.
  review https://gitlab.com/group/project/-/merge_requests/124
    Fetch that merge request, switch to its exact source branch state, and print the review prompt.
  review --duo --comment
    Print a prompt that includes unresolved GitLab Duo comments for the current branch's open MR and asks Copilot to comment findings back on it.
EOF
}

fail() {
  echo "review: $1" >&2
  exit 1
}

append_prompt() {
  prompt=$(printf '%s\n\n%s' "$prompt" "$1")
}

require_command_with_help() {
  command_name=$1
  install_hint=$2

  if ! command -v "$command_name" >/dev/null 2>&1; then
    if [ -n "$install_hint" ]; then
      fail "required command not found: $command_name. $install_hint"
    fi
    fail "required command not found: $command_name"
  fi
}

try_parse_gitlab_remote() {
  remote_url=$1

  if [ -z "$remote_url" ]; then
    return 1
  fi

  case "$remote_url" in
    git@*:*)
      parsed_gitlab_scheme="https"
      parsed_gitlab_host=${remote_url#git@}
      parsed_gitlab_host=${parsed_gitlab_host%%:*}
      parsed_gitlab_project_path=${remote_url#*:}
      ;;
    ssh://git@*/*)
      parsed_gitlab_scheme="https"
      remote_rest=${remote_url#ssh://git@}
      parsed_gitlab_host=${remote_rest%%/*}
      parsed_gitlab_project_path=${remote_rest#*/}
      ;;
    http://*/*)
      parsed_gitlab_scheme="http"
      remote_rest=${remote_url#http://}
      parsed_gitlab_host=${remote_rest%%/*}
      parsed_gitlab_project_path=${remote_rest#*/}
      ;;
    https://*/*)
      parsed_gitlab_scheme="https"
      remote_rest=${remote_url#https://}
      parsed_gitlab_host=${remote_rest%%/*}
      parsed_gitlab_project_path=${remote_rest#*/}
      ;;
    *)
      return 1
      ;;
  esac

  parsed_gitlab_project_path=${parsed_gitlab_project_path%.git}

  if [ -z "$parsed_gitlab_host" ] || [ -z "$parsed_gitlab_project_path" ]; then
    return 1
  fi

  return 0
}

parse_gitlab_remote() {
  remote_url=$1

  if ! try_parse_gitlab_remote "$remote_url"; then
    if [ -z "$remote_url" ]; then
      fail "could not determine the Git remote URL. Set the branch remote or rerun without GitLab options."
    fi
    fail "unsupported remote URL for GitLab options: $remote_url. Use a GitLab SSH or HTTPS remote."
  fi

  gitlab_scheme=$parsed_gitlab_scheme
  gitlab_host=$parsed_gitlab_host
  gitlab_project_path=$parsed_gitlab_project_path
}

try_parse_merge_request_url() {
  mr_url=$1

  case "$mr_url" in
    http://*/*/-/merge_requests/*|https://*/*/-/merge_requests/*)
      ;;
    *)
      return 1
      ;;
  esac

  parsed_mr_scheme=${mr_url%%://*}
  mr_url_without_scheme=${mr_url#*://}
  parsed_mr_host=${mr_url_without_scheme%%/*}
  mr_url_path=${mr_url_without_scheme#*/}

  case "$mr_url_path" in
    */-/merge_requests/*)
      ;;
    *)
      return 1
      ;;
  esac

  parsed_mr_project_path=${mr_url_path%%/-/merge_requests/*}
  parsed_mr_iid_part=${mr_url_path#"$parsed_mr_project_path"/-/merge_requests/}
  parsed_mr_iid=${parsed_mr_iid_part%%[/?#]*}

  case "$parsed_mr_iid" in
    ""|*[!0-9]*)
      return 1
      ;;
  esac

  if [ -z "$parsed_mr_host" ] || [ -z "$parsed_mr_project_path" ]; then
    return 1
  fi

  return 0
}

is_merge_request_url() {
  try_parse_merge_request_url "$1"
}

parse_merge_request_url() {
  mr_url=$1

  if ! try_parse_merge_request_url "$mr_url"; then
    fail "invalid merge request URL: $mr_url"
  fi
}

urlencode() {
  printf '%s' "$1" | jq -sRr @uri
}

gitlab_get_with_base() {
  api_base=$1
  endpoint=$2

  curl --silent --show-error --fail \
    --header "PRIVATE-TOKEN: $gitlab_token" \
    "$api_base/$endpoint"
}

gitlab_get() {
  gitlab_get_with_base "$gitlab_api_base" "$1"
}

resolve_base_ref() {
  candidate=$1

  if [ -z "$candidate" ]; then
    fail "--base requires a branch name, commit hash, or merge request URL"
  fi

  if git show-ref --verify --quiet "refs/remotes/origin/$candidate"; then
    base_ref="origin/$candidate"
  elif git show-ref --verify --quiet "refs/heads/$candidate"; then
    base_ref="$candidate"
  elif git rev-parse --verify --quiet "$candidate^{commit}" >/dev/null 2>&1; then
    base_ref="$candidate"
  else
    fail "could not resolve base reference '$candidate'"
  fi
}

ensure_gitlab_prerequisites() {
  require_command_with_help curl "Install it with Homebrew: brew install curl"
  require_command_with_help jq "Install it with Homebrew: brew install jq"

  gitlab_token=${GITLAB_TOKEN-}
  if [ -z "$gitlab_token" ]; then
    gitlab_token=${GITLAB_ACCESS_TOKEN-}
  fi

  if [ -z "$gitlab_token" ]; then
    cat >&2 <<EOF
review: GitLab options require GITLAB_TOKEN or GITLAB_ACCESS_TOKEN.

Fix it by exporting one of them before running review, for example:
  export GITLAB_TOKEN=<your-gitlab-token>

Then rerun the command.
EOF
    exit 1
  fi
}

load_merge_request_from_url() {
  mr_url=$1

  parse_merge_request_url "$mr_url"

  loaded_mr_scheme=$parsed_mr_scheme
  loaded_mr_host=$parsed_mr_host
  loaded_mr_project_path=$parsed_mr_project_path
  loaded_mr_iid=$parsed_mr_iid
  loaded_mr_encoded_project_path=$(urlencode "$loaded_mr_project_path")
  loaded_mr_api_base="$loaded_mr_scheme://$loaded_mr_host/api/v4"

  if ! loaded_mr_json=$(gitlab_get_with_base "$loaded_mr_api_base" "projects/$loaded_mr_encoded_project_path/merge_requests/$loaded_mr_iid"); then
    fail "failed to load merge request from URL: $mr_url. Check that the URL is correct and that your token can read it."
  fi

  loaded_mr_title=$(printf '%s' "$loaded_mr_json" | jq -r '.title')
  loaded_mr_web_url=$(printf '%s' "$loaded_mr_json" | jq -r '.web_url')
  loaded_mr_source_branch=$(printf '%s' "$loaded_mr_json" | jq -r '.source_branch')
  loaded_mr_base_sha=$(printf '%s' "$loaded_mr_json" | jq -r '.diff_refs.base_sha')
  loaded_mr_start_sha=$(printf '%s' "$loaded_mr_json" | jq -r '.diff_refs.start_sha')
  loaded_mr_head_sha=$(printf '%s' "$loaded_mr_json" | jq -r '.diff_refs.head_sha')
  loaded_mr_project_id=$(printf '%s' "$loaded_mr_json" | jq -r '.project_id')
  loaded_mr_source_project_id=$(printf '%s' "$loaded_mr_json" | jq -r '.source_project_id')

  if [ -z "$loaded_mr_source_branch" ] || [ "$loaded_mr_source_branch" = "null" ]; then
    fail "merge request URL '$mr_url' does not expose a source branch."
  fi

  if [ "$loaded_mr_source_project_id" = "null" ] || [ -z "$loaded_mr_source_project_id" ] || [ "$loaded_mr_source_project_id" = "$loaded_mr_project_id" ]; then
    loaded_mr_source_project_path=$loaded_mr_project_path
  else
    if ! source_project_json=$(gitlab_get_with_base "$loaded_mr_api_base" "projects/$loaded_mr_source_project_id"); then
      fail "failed to load the source project for merge request '$mr_url'."
    fi

    loaded_mr_source_project_path=$(printf '%s' "$source_project_json" | jq -r '.path_with_namespace')

    if [ -z "$loaded_mr_source_project_path" ] || [ "$loaded_mr_source_project_path" = "null" ]; then
      fail "failed to determine the source project path for merge request '$mr_url'."
    fi
  fi
}

find_matching_remote_for_project() {
  desired_host=$1
  desired_project_path=$2
  matched_remote=""
  fallback_remote=""

  for remote_name in $(git remote); do
    remote_url=$(git config --get "remote.$remote_name.url" 2>/dev/null || true)
    if try_parse_gitlab_remote "$remote_url"; then
      if [ "$parsed_gitlab_host" = "$desired_host" ] && [ "$parsed_gitlab_project_path" = "$desired_project_path" ]; then
        if [ "$remote_name" = "origin" ]; then
          matched_remote=$remote_name
          break
        fi
        if [ -z "$fallback_remote" ]; then
          fallback_remote=$remote_name
        fi
      fi
    fi
  done

  if [ -z "$matched_remote" ]; then
    matched_remote=$fallback_remote
  fi

  if [ -z "$matched_remote" ]; then
    fail "no configured git remote matches GitLab project '$desired_project_path' on '$desired_host'. Add a matching remote and rerun."
  fi
}

find_matching_remote_for_branch() {
  branch_name=$1
  configured_remote=$(git config --get "branch.$branch_name.remote" 2>/dev/null || true)
  fallback_remote=""
  multiple_matches="false"
  matched_remote=""

  if [ -n "$configured_remote" ] && [ "$configured_remote" != "." ]; then
    if git ls-remote --exit-code --heads "$configured_remote" "$branch_name" >/dev/null 2>&1; then
      matched_remote=$configured_remote
      return
    fi
  fi

  for remote_name in $(git remote); do
    if git ls-remote --exit-code --heads "$remote_name" "$branch_name" >/dev/null 2>&1; then
      if [ "$remote_name" = "origin" ]; then
        matched_remote=$remote_name
        return
      fi
      if [ -z "$fallback_remote" ]; then
        fallback_remote=$remote_name
      else
        multiple_matches="true"
      fi
    fi
  done

  if [ -n "$fallback_remote" ] && [ "$multiple_matches" != "true" ]; then
    matched_remote=$fallback_remote
    return
  fi

  if [ -n "$fallback_remote" ] && [ "$multiple_matches" = "true" ]; then
    fail "branch '$branch_name' exists on multiple remotes. Configure its upstream remote locally or use a merge request URL instead."
  fi

  fail "no remote branch named '$branch_name' was found. Push the branch first or use a merge request URL."
}

fetch_exact_remote_branch() {
  remote_name=$1
  branch_name=$2

  if ! git fetch --quiet "$remote_name" "$branch_name"; then
    fail "failed to fetch branch '$branch_name' from remote '$remote_name'."
  fi

  fetched_branch_sha=$(git rev-parse FETCH_HEAD)
  fetched_branch_track_ref=""

  if git show-ref --verify --quiet "refs/remotes/$remote_name/$branch_name"; then
    fetched_branch_track_ref="$remote_name/$branch_name"
  fi
}

ensure_clean_worktree_for_switch() {
  if [ -n "$(git status --porcelain --untracked-files=normal)" ]; then
    fail "working tree has uncommitted changes. Commit or stash them before reviewing another branch or merge request."
  fi
}

switch_to_exact_branch() {
  target_branch=$1
  target_sha=$2
  target_track_ref=$3

  ensure_clean_worktree_for_switch

  current_branch=$(git rev-parse --abbrev-ref HEAD)
  current_sha=$(git rev-parse HEAD)

  if git show-ref --verify --quiet "refs/heads/$target_branch"; then
    local_branch_sha=$(git rev-parse "refs/heads/$target_branch")

    if [ "$local_branch_sha" != "$target_sha" ]; then
      if ! git merge-base --is-ancestor "$local_branch_sha" "$target_sha" >/dev/null 2>&1; then
        if [ -n "$target_track_ref" ]; then
          fail "local branch '$target_branch' is not fast-forwardable to remote branch '$target_track_ref' (local $local_branch_sha, remote $target_sha). Update or delete the local branch and rerun."
        fi
        fail "local branch '$target_branch' is not fast-forwardable to the fetched branch commit (local $local_branch_sha, expected $target_sha). Update or delete the local branch and rerun."
      fi

      if [ "$current_branch" = "$target_branch" ]; then
        if [ -n "$target_track_ref" ]; then
          if ! git merge --ff-only --quiet "$target_track_ref"; then
            fail "failed to fast-forward branch '$target_branch' to remote branch '$target_track_ref'."
          fi
        else
          if ! git merge --ff-only --quiet "$target_sha"; then
            fail "failed to fast-forward branch '$target_branch' to commit '$target_sha'."
          fi
        fi
      else
        if ! git update-ref "refs/heads/$target_branch" "$target_sha" "$local_branch_sha"; then
          fail "failed to fast-forward local branch '$target_branch' to '$target_sha'."
        fi
      fi
    fi

    if [ "$current_branch" != "$target_branch" ]; then
      if ! git switch --quiet "$target_branch" 2>/dev/null; then
        if ! git checkout --quiet "$target_branch"; then
          fail "failed to switch to local branch '$target_branch'."
        fi
      fi
    fi
  else
    if [ -n "$target_track_ref" ]; then
      if ! git switch --quiet -c "$target_branch" --track "$target_track_ref" 2>/dev/null; then
        if ! git checkout --quiet -b "$target_branch" --track "$target_track_ref"; then
          fail "failed to create branch '$target_branch' from '$target_track_ref'."
        fi
      fi
    else
      if ! git switch --quiet -c "$target_branch" "$target_sha" 2>/dev/null; then
        if ! git checkout --quiet -b "$target_branch" "$target_sha"; then
          fail "failed to create branch '$target_branch' from commit '$target_sha'."
        fi
      fi
    fi
  fi

  current_branch=$(git rev-parse --abbrev-ref HEAD)
  current_sha=$(git rev-parse HEAD)

  if [ "$current_branch" != "$target_branch" ]; then
    fail "failed to switch to branch '$target_branch'."
  fi

  if [ "$current_sha" != "$target_sha" ]; then
    fail "switched to '$target_branch' but it does not match the fetched remote branch exactly (local $current_sha, expected $target_sha)."
  fi
}

set_primary_merge_request_context_from_loaded() {
  primary_mr_context_loaded="true"
  merge_request_iid=$loaded_mr_iid
  merge_request_title=$loaded_mr_title
  merge_request_url=$loaded_mr_web_url
  merge_request_source_branch=$loaded_mr_source_branch
  gitlab_host=$loaded_mr_host
  gitlab_project_path=$loaded_mr_project_path
  encoded_project_path=$loaded_mr_encoded_project_path
  gitlab_api_base=$loaded_mr_api_base
  mr_base_sha=$loaded_mr_base_sha
  mr_start_sha=$loaded_mr_start_sha
  mr_head_sha=$loaded_mr_head_sha

  if [ "$mr_base_sha" = "null" ] || [ "$mr_start_sha" = "null" ] || [ "$mr_head_sha" = "null" ]; then
    fail "merge request !${merge_request_iid} is missing diff refs. Wait for GitLab to prepare the diff and rerun."
  fi

  mr_discussions_endpoint="$gitlab_api_base/projects/$encoded_project_path/merge_requests/$merge_request_iid/discussions"
  mr_notes_endpoint="$gitlab_api_base/projects/$encoded_project_path/merge_requests/$merge_request_iid/notes"
}

load_primary_merge_request_for_current_branch() {
  current_branch=$(git rev-parse --abbrev-ref HEAD)

  if [ "$current_branch" = "HEAD" ]; then
    fail "GitLab review features require a checked-out branch. Run 'git switch <branch>' and rerun."
  fi

  branch_remote=$(git config --get "branch.$current_branch.remote" 2>/dev/null || true)
  if [ -z "$branch_remote" ] || [ "$branch_remote" = "." ]; then
    branch_remote="origin"
  fi

  remote_url=$(git config --get "remote.$branch_remote.url" 2>/dev/null || true)
  parse_gitlab_remote "$remote_url"
  gitlab_api_base="$gitlab_scheme://$gitlab_host/api/v4"
  encoded_project_path=$(urlencode "$gitlab_project_path")
  encoded_branch=$(urlencode "$current_branch")

  if ! merge_requests_json=$(gitlab_get "projects/$encoded_project_path/merge_requests?state=opened&source_branch=$encoded_branch&per_page=2"); then
    fail "failed to query open merge requests for branch '$current_branch'. Check that the remote points to GitLab and that your token has API access."
  fi

  merge_request_count=$(printf '%s' "$merge_requests_json" | jq 'length')
  case "$merge_request_count" in
    0)
      fail "no open merge request found for branch '$current_branch' in '$gitlab_project_path'. Open the merge request or rerun without GitLab review options."
      ;;
    1)
      ;;
    *)
      fail "multiple open merge requests found for branch '$current_branch' in '$gitlab_project_path'. Close the extras or use a unique source branch."
      ;;
  esac

  merge_request_iid=$(printf '%s' "$merge_requests_json" | jq -r '.[0].iid')

  if ! merge_request_detail_json=$(gitlab_get "projects/$encoded_project_path/merge_requests/$merge_request_iid"); then
    fail "failed to load merge request !${merge_request_iid}. Check that your token can read merge requests."
  fi

  merge_request_title=$(printf '%s' "$merge_request_detail_json" | jq -r '.title')
  merge_request_url=$(printf '%s' "$merge_request_detail_json" | jq -r '.web_url')
  merge_request_source_branch=$(printf '%s' "$merge_request_detail_json" | jq -r '.source_branch')
  mr_base_sha=$(printf '%s' "$merge_request_detail_json" | jq -r '.diff_refs.base_sha')
  mr_start_sha=$(printf '%s' "$merge_request_detail_json" | jq -r '.diff_refs.start_sha')
  mr_head_sha=$(printf '%s' "$merge_request_detail_json" | jq -r '.diff_refs.head_sha')

  if [ "$mr_base_sha" = "null" ] || [ "$mr_start_sha" = "null" ] || [ "$mr_head_sha" = "null" ]; then
    fail "merge request !${merge_request_iid} is missing diff refs. Wait for GitLab to prepare the diff and rerun."
  fi

  mr_discussions_endpoint="$gitlab_api_base/projects/$encoded_project_path/merge_requests/$merge_request_iid/discussions"
  mr_notes_endpoint="$gitlab_api_base/projects/$encoded_project_path/merge_requests/$merge_request_iid/notes"
  primary_mr_context_loaded="true"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --copilot)
      mode="copilot"
      ;;
    --duo)
      include_duo="true"
      ;;
    --resolve)
      resolve_duo="true"
      ;;
    --comment)
      comment_on_mr="true"
      ;;
    --base)
      shift
      if [ "$#" -eq 0 ]; then
        fail "--base requires a branch name, commit hash, or merge request URL"
      fi
      requested_base=$1
      explicit_base="true"
      ;;
    --base=*)
      requested_base=${1#--base=}
      explicit_base="true"
      if [ -z "$requested_base" ]; then
        fail "--base requires a branch name, commit hash, or merge request URL"
      fi
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      if [ -z "$requested_mr_url" ] && [ -z "$requested_review_branch" ]; then
        if is_merge_request_url "$1"; then
          requested_mr_url=$1
        else
          requested_review_branch=$1
        fi
      else
        usage >&2
        exit 1
      fi
      ;;
  esac
  shift
done

if [ "$resolve_duo" = "true" ] && [ "$include_duo" != "true" ]; then
  fail "--resolve requires --duo"
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  fail "not inside a Git repository"
fi

if is_merge_request_url "$requested_base"; then
  requested_base_is_mr_url="true"
fi

if [ -n "$requested_mr_url" ] || [ "$include_duo" = "true" ] || [ "$comment_on_mr" = "true" ]; then
  need_primary_mr_context="true"
fi

if [ "$need_primary_mr_context" = "true" ] || [ "$requested_base_is_mr_url" = "true" ]; then
  need_gitlab_api="true"
fi

if [ "$need_gitlab_api" = "true" ]; then
  ensure_gitlab_prerequisites
fi

if [ -n "$requested_review_branch" ]; then
  find_matching_remote_for_branch "$requested_review_branch"
  fetch_exact_remote_branch "$matched_remote" "$requested_review_branch"
  switch_to_exact_branch "$requested_review_branch" "$fetched_branch_sha" "$fetched_branch_track_ref"
fi

if [ -n "$requested_mr_url" ]; then
  load_merge_request_from_url "$requested_mr_url"
  find_matching_remote_for_project "$loaded_mr_host" "$loaded_mr_source_project_path"
  fetch_exact_remote_branch "$matched_remote" "$loaded_mr_source_branch"
  switch_to_exact_branch "$loaded_mr_source_branch" "$fetched_branch_sha" "$fetched_branch_track_ref"
  set_primary_merge_request_context_from_loaded
fi

if [ "$requested_base_is_mr_url" = "true" ]; then
  load_merge_request_from_url "$requested_base"
  find_matching_remote_for_project "$loaded_mr_host" "$loaded_mr_source_project_path"
  fetch_exact_remote_branch "$matched_remote" "$loaded_mr_source_branch"
  base_ref=$fetched_branch_sha
  base_description=$(printf "source branch '%s' from merge request '%s'" "$loaded_mr_source_branch" "$loaded_mr_web_url")
else
  resolve_base_ref "$requested_base"

  if [ "$explicit_base" = "true" ]; then
    if [ "$base_ref" = "$requested_base" ]; then
      base_description=$(printf "base reference '%s'" "$requested_base")
    else
      base_description=$(printf "requested base reference '%s' (resolved locally as '%s')" "$requested_base" "$base_ref")
    fi
  else
    if [ "$base_ref" = "$default_base" ]; then
      base_description=$(printf "base branch '%s'" "$default_base")
    else
      base_description=$(printf "base branch '%s' (resolved locally as '%s')" "$default_base" "$base_ref")
    fi
  fi
fi

if [ "$need_primary_mr_context" = "true" ] && [ "$primary_mr_context_loaded" != "true" ]; then
  load_primary_merge_request_for_current_branch
fi

if ! merge_base=$(git merge-base HEAD "$base_ref"); then
  fail "failed to determine merge base against '$base_ref'"
fi

prompt=$(printf "Review the code changes against the %s. The merge base commit for this comparison is %s. Run \`git diff %s\` to inspect the changes included since that merge base. Provide prioritized, actionable findings." \
  "$base_description" \
  "$merge_base" \
  "$merge_base")

if [ "$primary_mr_context_loaded" = "true" ]; then
  mr_context=$(printf "This review targets the GitLab merge request %s (project %s, IID !%s, title: %s, source branch: %s)." \
    "$merge_request_url" \
    "$gitlab_project_path" \
    "$merge_request_iid" \
    "$merge_request_title" \
    "$merge_request_source_branch")
  append_prompt "$mr_context"
fi

gitlab_shell_safety_context=$(printf "If you use shell commands for GitLab API calls, the shell safety scanner rejects any command containing the literal \`\${\` sequence, even inside quoted text, heredocs, or embedded JavaScript. Do not use \`\${...}\` shell expansion, \`\${...}\` fallback expressions, or JavaScript template literals in commands. Use plain \$GITLAB_TOKEN or \$GITLAB_ACCESS_TOKEN references after checking which variable is exported, use simple string concatenation, and paraphrase any reply or comment text that would otherwise contain the exact \`\${\` sequence.")

if [ "$include_duo" = "true" ]; then
  if ! discussions_json=$(gitlab_get "projects/$encoded_project_path/merge_requests/$merge_request_iid/discussions?per_page=100"); then
    fail "failed to load merge request discussions for !${merge_request_iid}. Check that your token can read discussions."
  fi

  duo_comments=$(printf '%s' "$discussions_json" | jq -r '
    [
      .[]
      | .id as $discussion_id
      | .notes[]
      | select(.author.username == "GitLabDuo" and .resolvable == true and (.resolved // false) == false)
      | {
          discussion_id: $discussion_id,
          note_id: (.id | tostring),
          status: "unresolved",
          location: (
            if .position == null then
              "general"
            else
              (.position.new_path // .position.old_path // "unknown")
              + (
                  if (.position.new_line // .position.old_line) != null then
                    ":" + ((.position.new_line // .position.old_line) | tostring)
                  else
                    ""
                  end
                )
            end
          ),
          body: .body
        }
    ]
    | if length == 0 then
        "No unresolved GitLab Duo comments were found on the target merge request."
      else
        map(
          "- discussion " + .discussion_id
          + ", note " + .note_id
          + ", " + .status
          + ", location: " + .location
          + "\n" + .body
        )
        | join("\n\n")
      end
  ')

  duo_context=$(printf "GitLab Duo comments can be useful hints, but validate them against the actual code and behavior because some may be incorrect, irrelevant, or overly nitpicky. Only unresolved GitLab Duo comments are included below; resolved comments are intentionally ignored.\n\nEach entry below includes the GitLab discussion ID, note ID, status, and location.\n\nGitLab Duo comments:\n%s" \
    "$duo_comments")
  append_prompt "$duo_context"

  if [ "$resolve_duo" = "true" ]; then
    unresolved_duo_comments=$(printf '%s' "$discussions_json" | jq '
      [
        .[]
        | .notes[]
        | select(.author.username == "GitLabDuo" and .resolvable == true and (.resolved // false) == false)
      ]
      | length
    ')

    if [ "$unresolved_duo_comments" -gt 0 ]; then
      resolve_context=$(printf "Also evaluate the unresolved GitLab Duo discussions above. For each Duo discussion that is incorrect, irrelevant, or too nitpicky, reply in the merge request thread with a concise explanation and resolve it. Do not resolve valid comments unless you address them with code changes or a clear rationale. Keep replies short and factual.\n\n%s\n\nGitLab API for Duo replies:\n- Reply: POST %s/<discussion_id>/notes with form field body=<reply>\n- Resolve: PUT %s/<discussion_id>?resolved=true\n- Use whichever of \$GITLAB_TOKEN or \$GITLAB_ACCESS_TOKEN is already exported; avoid inline fallback expressions." \
        "$gitlab_shell_safety_context" \
        "$mr_discussions_endpoint" \
        "$mr_discussions_endpoint")
      append_prompt "$resolve_context"
    else
      append_prompt "There are no unresolved GitLab Duo discussions to reply to or resolve."
    fi
  fi
fi

if [ "$comment_on_mr" = "true" ]; then
  comment_context=$(printf "Post substantive review findings directly to the target GitLab merge request as inline diff comments on the most relevant changed line. Only post real, actionable issues tied to the change. Skip style nits, speculative concerns, and duplicate threads. If there are no worthwhile findings, do not post any merge request comments.\n\n%s\n\nGitLab API for inline diff comments:\n- Endpoint: POST %s\n- Auth header: PRIVATE-TOKEN: use whichever of \$GITLAB_TOKEN or \$GITLAB_ACCESS_TOKEN is already exported; avoid inline fallback expressions.\n- Required position fields for text diff comments:\n  body=<comment>\n  position[position_type]=text\n  position[base_sha]=%s\n  position[start_sha]=%s\n  position[head_sha]=%s\n  position[old_path]=<file path before the change>\n  position[new_path]=<file path after the change>\n  position[new_line]=<line number> for added or changed lines, or position[old_line]=<line number> for removed lines\n- When the file was not renamed, old_path and new_path are the same path.\n- If GitLab rejects the position, inspect the merge request diff metadata first and retry with a valid changed line instead of immediately falling back to a general note.\n- If a finding truly does not map to a changed line, post one concise general merge request note to: POST %s" \
    "$gitlab_shell_safety_context" \
    "$mr_discussions_endpoint" \
    "$mr_base_sha" \
    "$mr_start_sha" \
    "$mr_head_sha" \
    "$mr_notes_endpoint")
  append_prompt "$comment_context"
fi

if [ "$mode" = "copilot" ]; then
  require_command_with_help copilot "Install GitHub Copilot CLI or rerun without --copilot."
  exec copilot -i "$prompt"
fi

printf "%s\n" "$prompt"
